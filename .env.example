# 🦞 CiCi 配置

# LLM 配置（DeepSeek / OpenAI / Anthropic 兼容接口）
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# 执行后端: "adb" (USB/WiFi ADB) 或 "hermes" (Hermes REST API WiFi)
EXECUTOR_BACKEND=adb

# ADB 路径
ADB_PATH=adb

# Hermes REST API 配置（EXECUTOR_BACKEND=hermes 时使用）
HERMES_HOST=192.168.1.100
HERMES_PORT=9527
HERMES_TOKEN=

# 飞书 Webhook 配置
FEISHU_WEBHOOK_PORT=5000
FEISHU_VERIFY_TOKEN=your_verify_token

# 安全限制
MAX_TAPS=5
MAX_EXECUTION_TIME=60
MAX_STEPS=30
